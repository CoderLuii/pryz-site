---
import '../styles/global.css';

const title = '404 - Pryz';
const description = 'The page you requested could not be found.';
const url = 'https://pryz.coderluii.dev/404';
const ogImage = 'https://pryz.coderluii.dev/promo/pryz/pryz-og.png';
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#14B8A6" />
  <meta name="description" content={description} />
  <meta name="author" content="CoderLuii" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@CoderLuii" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <title>{title}</title>
</head>

<body class="min-h-screen font-sans antialiased">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:bg-[#14B8A6] focus:text-[#050505] focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm focus:font-semibold">Skip to content</a>

  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-[#334155]/50 bg-[#0F172A]/80 backdrop-blur-md">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6">
      <a href="/" class="flex items-center gap-2 text-lg font-bold">
        <img src="/promo/pryz/logo.png" alt="Pryz" width="32" height="32" class="rounded-lg" />
        <span class="bg-gradient-to-r from-[#14B8A6] to-[#8B5CF6] bg-clip-text text-transparent">Pryz</span>
      </a>
      <a href="/" class="rounded-lg border border-[#334155] px-3 py-1.5 text-sm text-[#CBD5E1] transition-colors hover:border-[#14B8A6]/50 hover:text-white">Back home</a>
    </div>
  </nav>

  <main id="main-content" class="hero-mesh flex min-h-screen items-center justify-center px-4 pt-24 pb-16 sm:px-6">
    <section class="w-full max-w-2xl rounded-3xl border border-[#334155]/70 bg-[#1E293B]/85 p-8 text-center shadow-2xl shadow-black/20 sm:p-12">
      <div class="mx-auto mb-6 inline-flex h-16 w-16 items-center justify-center rounded-2xl border border-[#14B8A6]/30 bg-[#14B8A6]/10 text-2xl font-bold text-[#14B8A6]">
        404
      </div>
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-[#14B8A6]">Page not found</p>
      <h1 class="mb-4 text-3xl font-bold text-white sm:text-5xl">That route doesn’t exist.</h1>
      <p class="mx-auto mb-8 max-w-xl text-base leading-7 text-[#94A3B8] sm:text-lg">
        The page may have moved, the link may be outdated, or the URL may be wrong.
        Head back to the Pryz homepage and rejoin the waitlist from there.
      </p>

      <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="/" class="inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-[#14B8A6] to-[#8B5CF6] px-6 py-3 text-sm font-semibold text-white transition-transform hover:-translate-y-0.5">
          Return to homepage
        </a>
        <a href="https://coderluii.dev" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-xl border border-[#334155] px-6 py-3 text-sm font-semibold text-[#CBD5E1] transition-colors hover:border-[#14B8A6]/50 hover:text-white">
          Visit CoderLuii
        </a>
      </div>
    </section>
  </main>

  <footer class="border-t border-[#334155]/50 py-8 sm:py-10">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-4 text-sm text-[#94A3B8] sm:flex-row sm:px-6">
      <div class="flex items-center gap-2">
        <img src="/promo/pryz/logo.png" alt="Pryz" width="20" height="20" class="rounded" />
        <span class="bg-gradient-to-r from-[#14B8A6] to-[#8B5CF6] bg-clip-text font-bold text-transparent">Pryz</span>
      </div>
      <p>Built by <a href="https://coderluii.dev" target="_blank" rel="noopener noreferrer" class="text-[#CBD5E1] transition-colors hover:text-[#14B8A6]">CoderLuii</a></p>
    </div>
  </footer>
</body>
</html>
