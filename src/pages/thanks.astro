---
import LandingLayout from '../layouts/LandingLayout.astro';
---

<LandingLayout
  title="You're on the list — Pryz"
  description="Thanks for joining the Pryz waitlist."
  product="Pryz"
>
  <section class="flex items-center justify-center px-6" style="min-height: 80vh;">
    <div class="text-center max-w-lg fade-in">
      <div class="text-5xl mb-6">🎉</div>
      <h1 class="text-3xl md:text-4xl font-bold mb-4 gradient-text">You're on the list</h1>
      <p class="text-base mb-8" style="color: var(--text-muted);">Thanks for joining the Pryz waitlist. We'll let you know as soon as early access opens.</p>
      <div class="flex items-center justify-center gap-4 flex-wrap">
          <a href="/" class="inline-block px-7 py-3.5 rounded-full font-semibold text-sm ring-1 ring-white/[0.12] transition-all duration-700 active:scale-[0.98] hover:no-underline" style="color: var(--text);">
            Back to Pryz
          </a>
        <a href="https://discord.gg/mthsvesKpC" target="_blank" rel="noopener noreferrer" class="inline-block px-7 py-3.5 rounded-full font-semibold text-sm ring-1 ring-white/[0.12] transition-all duration-700 active:scale-[0.98] hover:no-underline" style="color: var(--text);">
          Join Discord
        </a>
        <a href="https://x.com/CoderLuii" target="_blank" rel="noopener noreferrer" class="inline-block px-7 py-3.5 rounded-full font-semibold text-sm transition-all duration-700 active:scale-[0.98] hover:no-underline" style="background: linear-gradient(135deg, #14B8A6, #0d9488); color: #fff;">
          Follow @CoderLuii
        </a>
      </div>
      <div class="mt-8 pt-6" style="border-top: 1px solid rgba(255,255,255,0.06);">
        <p class="text-xs mb-3" style="color: var(--text-muted);">Spread the word</p>
        <div class="flex items-center justify-center gap-3">
          <a href="https://x.com/intent/tweet?text=Just%20joined%20the%20Pryz%20waitlist%20by%20%40CoderLuii%20%E2%80%94%20check%20it%20out%21&url=https%3A%2F%2Fpryz.coderluii.dev" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-medium ring-1 ring-white/[0.08] transition-all duration-300 hover:ring-white/[0.2] hover:no-underline" style="color: var(--text-muted);">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Share on X
          </a>
          <button onclick="navigator.clipboard.writeText('https://pryz.coderluii.dev');this.textContent='Copied!';setTimeout(()=>this.textContent='Copy Link',2000)" class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-medium ring-1 ring-white/[0.08] transition-all duration-300 hover:ring-white/[0.2] cursor-pointer" style="color: var(--text-muted); background: none; border: none;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            Copy Link
          </button>
        </div>
      </div>
    </div>
  </section>
</LandingLayout>
